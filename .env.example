# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Required: your Dune API key (dune.com/settings/api)
DUNE_API_KEY=your_api_key_here

# Required: your Dune team name (e.g. my_team)
DUNE_TEAM_NAME=your_team_name_here

# Optional: appended to dev schema name to avoid collisions (e.g. your first name)
DEV_SCHEMA_SUFFIX=your_name_here

# Factory addresses sheet URL — public, not a secret.
# The GitHub Actions sync workflow has this hardcoded and works without any setup.
# Add it here only if you want the $FACTORY_ADDRESSES_SHEET_URL shorthand locally.
# FACTORY_ADDRESSES_SHEET_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vQeFuICoQ1AjXrDKBW9E6Yf4PlTHPi1lDDzDAFrONa0otYiwLuX3ujF9S3uF5OWhj1E3ANylQVI_lSe/pub?output=csv
